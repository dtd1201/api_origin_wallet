APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS="your_email@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
AUTH_EXPOSE_VERIFICATION_CODE=false
AUTH_ADMIN_ROLE_CODES=admin,super_admin
GOOGLE_CLIENT_ID=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FULL_NAME="Origin Wallet Super Admin"

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://khoinguyenoriginwallet.com
CORS_ALLOWED_HEADERS=Content-Type,X-Requested-With,Authorization,Accept,Origin
CORS_SUPPORTS_CREDENTIALS=false

CURRENXIE_BASE_URL=
CURRENXIE_AUTH_MODE=static_headers
CURRENXIE_API_KEY=
CURRENXIE_API_SECRET=
CURRENXIE_BEARER_TOKEN=
CURRENXIE_TOKEN_URL=
CURRENXIE_TOKEN_ENDPOINT=/oauth2/token
CURRENXIE_CLIENT_ID=
CURRENXIE_CLIENT_SECRET=
CURRENXIE_SCOPE=
CURRENXIE_AUDIENCE=
CURRENXIE_AUTH_CREDENTIALS_IN=body
CURRENXIE_TOKEN_CACHE_KEY=provider_http_client:currenxie:access_token
CURRENXIE_TOKEN_CACHE_BUFFER_SECONDS=30
CURRENXIE_TIMEOUT=30
CURRENXIE_CUSTOMER_ENDPOINT=/customers
CURRENXIE_ACCOUNT_ENDPOINT=/accounts
CURRENXIE_ACCOUNTS_SYNC_ENDPOINT=/accounts
CURRENXIE_BALANCES_SYNC_ENDPOINT=/balances
CURRENXIE_TRANSACTIONS_SYNC_ENDPOINT=/transactions
CURRENXIE_QUOTE_ENDPOINT=/quotes
CURRENXIE_TRANSFER_ENDPOINT=/transfers
CURRENXIE_BENEFICIARY_ENDPOINT=/beneficiaries
CURRENXIE_BENEFICIARY_UPDATE_ENDPOINT=/beneficiaries/{beneficiary}
CURRENXIE_BENEFICIARY_DELETE_ENDPOINT=/beneficiaries/{beneficiary}
CURRENXIE_WEBHOOK_SECRET=
CURRENXIE_WEBHOOK_SIGNATURE_HEADER=X-Currenxie-Signature
CURRENXIE_WEBHOOK_SIGNATURE_ALGORITHM=sha256

WISE_BASE_URL=
WISE_AUTH_MODE=client_credentials
WISE_BEARER_TOKEN=
WISE_TOKEN_URL=
WISE_TOKEN_ENDPOINT=
WISE_CLIENT_ID=
WISE_CLIENT_SECRET=
WISE_SCOPE=
WISE_AUDIENCE=
WISE_AUTH_CREDENTIALS_IN=body
WISE_TOKEN_CACHE_KEY=provider_http_client:wise:access_token
WISE_TOKEN_CACHE_BUFFER_SECONDS=30
WISE_TIMEOUT=30
WISE_PROFILES_ENDPOINT=/v1/profiles
WISE_BALANCES_ENDPOINT=/v4/profiles/{profile}/balances
WISE_TRANSACTIONS_ENDPOINT=/v1/borderless-accounts/{profile}/statement.json
WISE_QUOTE_ENDPOINT=/v3/profiles/{profile}/quotes
WISE_TRANSFER_ENDPOINT=/v1/transfers
WISE_RECIPIENT_ENDPOINT=/v1/accounts
WISE_WEBHOOK_SECRET=

AIRWALLEX_BASE_URL=
AIRWALLEX_AUTH_MODE=none
AIRWALLEX_BEARER_TOKEN=
AIRWALLEX_TOKEN_URL=
AIRWALLEX_TOKEN_ENDPOINT=/api/v1/authentication/login
AIRWALLEX_CLIENT_ID=
AIRWALLEX_CLIENT_SECRET=
AIRWALLEX_API_KEY=
AIRWALLEX_SCOPE=
AIRWALLEX_AUDIENCE=
AIRWALLEX_AUTH_CREDENTIALS_IN=body
AIRWALLEX_TOKEN_CACHE_KEY=provider_http_client:airwallex:access_token
AIRWALLEX_TOKEN_CACHE_BUFFER_SECONDS=30
AIRWALLEX_TIMEOUT=30
AIRWALLEX_GLOBAL_ACCOUNTS_ENDPOINT=/api/v1/global_accounts
AIRWALLEX_BALANCES_ENDPOINT=/api/v1/balances/current
AIRWALLEX_TRANSACTIONS_ENDPOINT=/api/v1/pa/payment_events/search
AIRWALLEX_QUOTE_ENDPOINT=/api/v1/quotes/create
AIRWALLEX_TRANSFER_ENDPOINT=/api/v1/transfers/create
AIRWALLEX_BENEFICIARY_ENDPOINT=/api/v1/beneficiaries/create
AIRWALLEX_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

VITE_APP_NAME="${APP_NAME}"
